# ════════════════════════════════════════════════════════════════════════════
#  Lu Achadinhos 2.0 — variáveis de ambiente
#  Copie para .env e preencha. O .env NUNCA vai pro git (ver .gitignore).
# ════════════════════════════════════════════════════════════════════════════

# ── Banco de dados (PostgreSQL) ──────────────────────────────────────────────
# Em docker-compose, host = "db". Local solto, host = "localhost".
DATABASE_URL=postgresql://lu:lu@localhost:5432/luachadinhos

# ── Mercado Livre — afiliados ────────────────────────────────────────────────
MATT_WORD=
MATT_TOOL=
# Caminho do JSON de cookies p/ gerar link oficial (relativo à pasta secrets/)
COOKIES_FILE=secrets/ml_cookies.json

# ── Shopee — afiliados ───────────────────────────────────────────────────────
SHOPEE_APP_ID=
SHOPEE_SECRET=

# ── Telegram — controle / kill-switch ────────────────────────────────────────
BOT_TOKEN=
CHAT_ID_AUTORIZADO=

# ── Imagem padrão (mensagem de supermercado) ─────────────────────────────────
IMAGEM_SUPERMERCADO=

# ── Filtros padrão (sobrepostos pela tabela `config` no banco) ───────────────
FILTRO_DESCONTO_MIN=20
FILTRO_AVALIACAO_MIN=4.0
FILTRO_AVALIACOES_MIN=100
FILTRO_PRECO_MAX=0
DEDUP_THRESHOLD=0.55
TOP_POR_DISPARO=5

# ── WhatsApp service (micro-serviço Node/Baileys) ────────────────────────────
WHATSAPP_SERVICE_URL=http://localhost:3000
# IDs dos grupos destino, separados por vírgula (preenchidos depois)
WHATSAPP_GROUP_IDS=

# ── Operação ─────────────────────────────────────────────────────────────────
TZ=America/Sao_Paulo
# Slots de disparo (HH:MM) — usados pelo cron/scripts, referência:
SLOT_MANHA=08:00
SLOT_ALMOCO=13:00
SLOT_NOITE=19:00
